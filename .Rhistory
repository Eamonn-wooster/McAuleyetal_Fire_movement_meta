# Reading in Data
data <- read.csv(here("Outputs/Dat_for_MA_analysisRev5.csv"))
knitr::opts_chunk$set(echo = TRUE)
#knitr::opts_chunk$set(eval = FALSE)
# Loading Packages
pacman::p_load(devtools,
tidyverse,
metafor,
patchwork,
R.rsp, orchaRd,
emmeans,
metafor,
orchaRd,
stringr,
dplyr,
broom,
tidyverse,
here,
broom,
ggplot2,
viridis,
data.table,
Matrix,
matrixcalc,
ape,
multcomp,
kableExtra
)
# Reading in Data
data <- read.csv(here("Outputs/Dat_for_MA_analysisRev5.csv"))
# Reading in tree
tree1 <- read.tree(here("Outputs/Tree_fire-Rev4.tre"))
# Getting branch length and correlation matrix
tree1b <- compute.brlen(tree1)
cor1 <-  vcv(tree1b, corr=T)
# checking the match, needs to return 0
setdiff(data$Species_tree, tree1$tip.label)
# Calculating Hedge's G
es <- escalc(
measure = "SMD",
m1i = Mean_Fire,
sd1i = sd_Fire,
n1i = Burned_n,
m2i = Mean_Unburned,
sd2i = sd_Unburned,
n2i = Unburned_n,
data = data,
vtype = "UB")
# Inspecting results
print(es)
# Adding factor for obs level random effect
es$Obs_ID <- factor(1:nrow(es))
# Adding factor for study level random effect
es$StudyID <- NULL
es$Study_ID <- factor(as.numeric(as.factor(es$Firstauthor_Year)))
# Correcting direction of ES for Harris2020 tortuosity
es %>%
dplyr::filter(Firstauthor_Year %in% c("Harris2020"))
es <- es %>%
mutate(yi = ifelse(Obs_ID %in% c(91), yi * -1, yi))
# Matrix to account for non-independence in studies and observations
vcv <- vcalc(vi, cluster = Study_ID, obs = Obs_ID, rho = 0.5,
data = es)
str(es$Publication_Year)
mod_mad <- rma.mv(yi = yi, V = vcv,
random = list(~1 | Study_ID,
~1 | Species_tree, # phylo effect
~1 | Species2, # non-phylo effect
~1 | Obs_ID),
data = es,
mods = ~ Publication_Year,
control=list(optimizer="BFGS"),
test = "t",
sparse = TRUE,
R = list(Species_tree = cor1)
)
summary(mod_mad)
decline <- bubble_plot(mod_mad,
mod = "Publication_Year",
group = "Study_ID",
xlab = "Publication year",
ylab = "Hedge's g",
g = TRUE,
weights = 1/sqrt(es$vi))
decline
str(es$Publication_Year)
